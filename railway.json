{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd legacy/web && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd legacy/web && npx next start -p $PORT -H 0.0.0.0",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
