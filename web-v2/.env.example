# web-v2 environment.
# Copy to .env.local and fill in. .env.local is gitignored.

# Postgres connection (Railway prod or local). Required.
DATABASE_URL=postgres://user:pass@host:port/db

# Anthropic API key for the coach engine. Required for /api/briefing.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default user id (David) for /api/briefing.
# Most useful in dev when impersonating other users.
# DEFAULT_USER_ID=0645f40c-951d-4ccc-b86e-9979cd26c795

# ────────────────────────────────────────────────────────────────
# Sign in with Apple
# ────────────────────────────────────────────────────────────────
# Both the iPhone (native ASAuthorizationAppleIDProvider) and the web
# (AppleID.auth JS SDK) POST identity tokens to /api/auth/apple. The
# backend verifies iss / aud / exp on the JWT. The audience differs
# between surfaces · the backend accepts both.

# iOS bundle id · used as the JWT audience when iPhone signs in.
APPLE_AUDIENCE=run.faff.app

# Web Services ID · used as the JWT audience when web signs in.
# Separate from the bundle id · configured in Apple Developer ·
# Certificates, Identifiers & Profiles → Identifiers → Services IDs.
# When unset, the /login Apple button shows a "not configured" toast
# instead of throwing · the page still renders normally.
APPLE_SERVICES_ID=

# Web redirect URI registered against the Services ID above. Must match
# what Apple Developer expects exactly · trailing slash matters · case
# matters. Defaults to https://www.faff.run/login if unset, but you
# still have to register that URL on Apple's side.
APPLE_REDIRECT_URI=https://www.faff.run/login
