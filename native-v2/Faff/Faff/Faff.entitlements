<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  HealthKit capability is required because the bundle declares
	  NSHealthShareUsageDescription / NSHealthUpdateUsageDescription in
	  Info.plist. Without the entitlement, iOS rejects the app at launch
	  on real devices (crashed build 72 and 73). The legacy app at
	  legacy/native/Faff/Faff/Faff.entitlements has the same declaration.
	-->
	<key>com.apple.developer.healthkit</key>
	<true/>

	<!--
	  Shared app group with the watch app target. The legacy app uses
	  this for SharedDefaults; the v2 iPhone+watch pair use it the same
	  way. Bundle ID matches App Store Connect declaration.
	-->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.run.faff.app</string>
	</array>

	<!--
	  APNs / push notifications (deck 2026-05-28). 'development'
	  routes to the sandbox APNs endpoint when running a debug build;
	  'production' routes to api.push.apple.com. Apple resolves this
	  automatically based on the provisioning profile, so 'development'
	  here works for both sandbox + TestFlight.
	  Set APNS_PRODUCTION=1 in Railway env when shipping to App Store.
	-->
	<key>aps-environment</key>
	<string>development</string>

	<!--
	  Sign In with Apple. Components/SignInWithAppleView.swift uses
	  ASAuthorizationAppleIDProvider · without this entitlement the iOS
	  framework rejects the request with ASAuthorizationError.unknown
	  (error 1000) before reaching the network or our backend. The App
	  ID 'run.faff.app' must also have Sign In with Apple capability
	  enabled in Apple Developer Console (confirmed 2026-05-31).
	-->
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
</dict>
</plist>
